// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock Stock[]
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stock Stock[]
}

// Stock = how many units of a product exist in a specific warehouse
model Stock {
  id          String @id @default(cuid())
  productId   String
  warehouseId String

  // total: physical units in the warehouse
  // reserved: units currently held by a PENDING reservation
  // available = total - reserved  (computed in queries, not stored)
  total    Int @default(0)
  reserved Int @default(0)

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  reservations Reservation[]

  // A product can only have one stock entry per warehouse
  @@unique([productId, warehouseId])
}

model Reservation {
  id        String            @id @default(cuid())
  stockId   String
  quantity  Int
  status    ReservationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  stock Stock @relation(fields: [stockId], references: [id])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  RELEASED
}

// Stores idempotency keys so duplicate requests return the same response
model IdempotencyRecord {
  key        String   @id
  statusCode Int
  body       Json
  createdAt  DateTime @default(now())

  // Auto-expire after 24 hours (cleaned up lazily or by cron)
  expiresAt DateTime
}
